# Keep the build context small — anything not needed at runtime stays out.

# Secrets — must never enter the image
.env
.env.*
!.env.example

# VCS + local tooling
.git
.gitignore
.github
.vscode
.idea
.claude

# Python caches
__pycache__
*.py[cod]
*.so
.venv
venv
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Local data (cache + feedback) — mount as a volume in prod instead
kanoon_cache.sqlite
feedback.db
feedback.db-journal
*.sqlite
*.sqlite3

# Tests + dev-only
tests
scripts
legacy
docs
Dockerfile
.dockerignore
README.md
requirements-dev.txt
pyproject.toml

# OS artefacts
.DS_Store
Thumbs.db
*.swp
