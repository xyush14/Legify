# Secrets — never commit
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/
env/

# Local data
feedback.db
feedback.db-journal
*.sqlite
*.sqlite3
*.sqlite-wal
*.sqlite-shm
# Compressed corpus artifacts (the shippable full DB, built by
# scripts/build_shippable_corpus.py and uploaded to a host — never committed).
*.sqlite.gz
*.sqlite.zst
# EXCEPTION: the ~14MB core judgments DB (sc_judgments metadata + sc_tar_offsets,
# NO extracted text) is tracked + baked into the Docker image so the app can
# seed /data/judgments.sqlite on first boot. Rebuild it with:
#   python scripts/build_judgments_core.py --force
!judgments_core.sqlite
kanoon_cache/
.cache/

# Notion sync — local marker for scripts/notion_sync.py (last commit mirrored to Notion)
.notion_sync_state.json

# IDE / tooling
.vscode/
.idea/
.claude/
*.swp
.DS_Store

# Logs
*.log

# Courtbook competitive-research corpus — third-party content scraped from
# courtbook.in for roadmap analysis only (scripts/scrape_courtbook.py). Raw HTML
# cache + parsed JSONL + xlsx/md reports. NEVER committed, served, or rehosted.
.courtbook_cache/
research/courtbook/

# Reference templates — real client filings, scrubbed or unscrubbed,
# used to tune format_specs in headnote/drafter/compose_templates.py.
# Never committed — client names, FIR numbers, addresses must not leak
# into version control. The README in the folder is committed; everything
# else is local-only.
templates_reference/*
!templates_reference/README.md
_build/

# Exported user PII (Supabase snapshot) — never commit
headnote_contacts.csv

# Regional-language runtime write-back cache (machine translations, not verified)
headnote/drafter/i18n/machine/
