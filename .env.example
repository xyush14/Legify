# Copy this file to .env and fill in real values.
# .env is gitignored; .env.example is safe to commit.

ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Optional Gemini fallback. When Anthropic returns rate-limit (429),
# overloaded (529), or 5xx, the router retries the same call against
# Gemini 2.0 Flash (free tier: 15 req/min, 1500 req/day). Without this
# key set, Anthropic errors bubble up unchanged. Get one at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Indian Kanoon API token — register at https://api.indiankanoon.org/
INDIAN_KANOON_TOKEN=your-kanoon-token-here

# Daily IK API spend cap in INR (₹0.50/search, ₹0.20/doc, ₹0.02/docmeta).
# Calls that would exceed this are refused. Leave blank for no cap.
INDIAN_KANOON_DAILY_CAP_INR=100

# Sonnet -> Opus confidence-based auto-escalation. Set to 0 / false to
# disable temporarily (e.g. during a cost-spike incident). deep_mode in
# request still forces Opus.
ENABLE_OPUS_ESCALATION=true

# Bearer token for /admin/* routes (e.g. /admin/telemetry). Unset = admin
# routes return 503 ("not configured"). Generate with `openssl rand -hex 32`.
ADMIN_TOKEN=

# ---- Supabase auth (Google OAuth + onboarding)
# Get these from Supabase dashboard → Settings → API.
# The anon key is public-safe (constrained by RLS); still don't commit real values.
# Leave blank to run without auth (dev mode — auth modals will not appear).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ---- WhatsApp bot — provider selection
# Picks the outbound channel. Inbound provider is determined by which
# webhook URL receives the call (so both can run side-by-side).
WA_PROVIDER=twilio           # "twilio" (dev/sandbox) or "meta" (prod direct)

# ---- WhatsApp · Twilio (dev/sandbox path — no business verification needed)
# Sign up at twilio.com/try-twilio → Console → Messaging → WhatsApp Sandbox.
TWILIO_ACCOUNT_SID=          # starts with "AC..."
TWILIO_AUTH_TOKEN=           # used for Basic auth + webhook HMAC verify
TWILIO_WA_FROM=+14155238886  # the sandbox number Twilio assigns
TWILIO_WEBHOOK_URL=          # OPTIONAL — exact public URL Twilio calls (helps signature verify behind proxies)
TWILIO_SKIP_SIGNATURE_VERIFY=  # OPTIONAL — set to "1" to bypass verify entirely (sandbox/dev escape hatch)
TWILIO_WA_MEDIA_BASE_URL=    # OPTIONAL — public base URL for serving PDF attachments (Phase 2)

# ---- WhatsApp · Meta Cloud API (production path, ₹0 fixed cost at scale)
# Source values from developers.facebook.com → your-app → WhatsApp → API Setup.
# Walkthrough: docs/WHATSAPP_BOT_PRD.md §13 Phase 0.
WA_PHONE_NUMBER_ID=          # number ID Meta assigns to your bot phone
WA_ACCESS_TOKEN=             # System User permanent token (or temp 24h while testing)
WA_APP_SECRET=               # FB App Secret — used to HMAC-verify inbound webhooks
WA_VERIFY_TOKEN=             # arbitrary secret string we pick; submitted to Meta during webhook setup
WA_API_VERSION=v20.0         # optional override
